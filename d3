(*Function to calculate d3 for a given sample size n*)
d3[n_Integer] := 
 Module[{pdf, meanRange, 
   meanSquaredRange},(*Define the PDF of the range for standard \
normal samples*)
  pdf[w_] := 
   n*(n - 1)*
    NIntegrate[(CDF[NormalDistribution[0, 1], x] - 
         CDF[NormalDistribution[0, 1], x - w])^(n - 2)*
      PDF[NormalDistribution[0, 1], x - w]*
      PDF[NormalDistribution[0, 1], x], {x, -Infinity, Infinity}, 
     Method -> "GlobalAdaptive", PrecisionGoal -> 17];
  (*Calculate E[R]=d2*)
  meanRange = 
   NIntegrate[w*pdf[w], {w, 0, Infinity}, Method -> "GlobalAdaptive", 
    PrecisionGoal -> 17];
  (*Calculate E[R^2]*)
  meanSquaredRange = 
   NIntegrate[w^2*pdf[w], {w, 0, Infinity}, 
    Method -> "GlobalAdaptive", PrecisionGoal -> 17];
  (*d3=Sqrt[E[R^2]-(E[R])^2]*)Sqrt[meanSquaredRange - meanRange^2]]


